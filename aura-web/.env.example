# ==========================================
# AURA OS V2 - ENVIRONMENT VARIABLES
# ==========================================

# 1. SUPABASE (Required for Cloud Database & Auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 2. STRIPE (Required for B2B Billing - Phase 3)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# 3. KIRA AI (Optional - If self-hosting the AI Agent)
KIRA_API_KEY=
